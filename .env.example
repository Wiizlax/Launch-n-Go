# Variables lues par server/contact-api.ts (ne pas préfixer par VITE_)
# Copier vers .env et remplir (ne jamais committer .env)

RESEND_API_KEY=re_votre_cle_resend
CONTACT_RECIPIENT_EMAIL=votre@email.com

# Optionnel : origines front autorisées pour CORS, séparées par des virgules (URL exacte, sans / final)
# ALLOWED_ORIGIN=https://votre-domaine.fr,https://votre-projet.vercel.app
#
# Si chaque déploiement Vercel change l’URL (preview), soit tu ajoutes chaque URL ici, soit sur Render tu mets :
# ALLOW_VERCEL_PREVIEWS=true
# pour autoriser tout https://*.vercel.app (pratique en hobby ; en prod préfère un domaine fixe dans ALLOWED_ORIGIN).

# Optionnel : port local de l’API (défaut 3001). En prod (Render, etc.), utiliser PORT fourni par la plateforme.
# CONTACT_API_PORT=3001

# Front : URL de base de l’API si elle n’est pas sur la même origine (sans slash final)
# VITE_CONTACT_API_URL=https://api.example.com
