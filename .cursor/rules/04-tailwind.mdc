## `tailwind.config.ts` — Design system du projet

```ts
import type { Config } from 'tailwindcss'

const config: Config = {
  content: ['./index.html', './src/**/*.{ts,tsx}'],
  theme: {
    extend: {
      // ── Couleurs ──────────────────────────────────────────────
      colors: {
        primary: {
          DEFAULT: '#FF6B35',
          dark: '#E55A25',
          light: '#FF8F5E',
        },
        surface: {
          DEFAULT: '#F8F7F4',
          dark: '#EFEDE8',
        },
        dark: {
          DEFAULT: '#1A1A2E',
          light: '#2D2D44',
        },
        gray: {
          muted: '#9CA3AF',
        },
      },

      // ── Typographie ───────────────────────────────────────────
      fontFamily: {
        heading: ['Sora', 'sans-serif'],   // remplacer selon choix final
        body: ['DM Sans', 'sans-serif'],   // remplacer selon choix final
        mono: ['JetBrains Mono', 'monospace'],
      },

      // ── Espacements custom ────────────────────────────────────
      spacing: {
        section: '6rem',       // py-section pour les sections
        'section-sm': '4rem',  // mobile
      },

      // ── Container ─────────────────────────────────────────────
      container: {
        center: true,
        padding: {
          DEFAULT: '1rem',
          sm: '1.5rem',
          lg: '2rem',
        },
        screens: {
          xl: '1280px',
        },
      },

      // ── Ombres ────────────────────────────────────────────────
      boxShadow: {
        card: '0 4px 24px -4px rgba(0,0,0,0.08)',
        'card-hover': '0 12px 40px -8px rgba(0,0,0,0.16)',
        'primary-glow': '0 8px 24px -4px rgba(255,107,53,0.35)',
      },

      // ── Border radius ─────────────────────────────────────────
      borderRadius: {
        xl: '1rem',
        '2xl': '1.5rem',
        '3xl': '2rem',
      },
    },
  },
  plugins: [],
}

export default config
```

