## `src/types/index.ts` — Types correspondants

```ts
// src/types/service.ts
export interface Service {
  id: string
  icon: string
  title: string
  description: string
  href?: string
}

// src/types/project.ts
export interface Project {
  id: string
  label: string
  labelColor: 'orange' | 'blue' | 'green' | 'purple'
  title: string
  description: string
  image: string
  tags: string[]
  href?: string
}

// src/types/testimonial.ts
export interface Testimonial {
  id: string
  name: string
  role: string
  avatar: string
  rating: 1 | 2 | 3 | 4 | 5
  content: string
}

// src/types/stat.ts
export interface Stat {
  id: string
  value: number
  suffix: string
  label: string
}

// src/types/navigation.ts
export interface NavItem {
  label: string
  href: string
  external?: boolean
}

// src/types/index.ts — barrel
export type { Service } from './service'
export type { Project } from './project'
export type { Testimonial } from './testimonial'
export type { Stat } from './stat'
export type { NavItem } from './navigation'
```

