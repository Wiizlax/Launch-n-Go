## `src/constants/index.ts` — Barrel export

```ts
// src/constants/index.ts
export { SITE_CONFIG } from './site'
export { NAV_ITEMS } from './navigation'
export { SERVICES } from './services'
export { PROJECTS } from './projects'
export { TESTIMONIALS } from './testimonials'
export { PROCESS_STEPS } from './process'
export { STATS } from './stats'
// Les animations sont importées directement depuis animations.ts (trop nombreuses pour un barrel)
```

