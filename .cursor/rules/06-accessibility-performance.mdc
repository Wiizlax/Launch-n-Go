## Focus visible — navigation clavier

```css
/* src/styles/index.css — focus cohérent sur tout le site */
@layer base {
  /* Focus visible uniquement au clavier (pas au clic souris) */
  *:focus-visible {
    @apply outline-none ring-2 ring-primary ring-offset-2 ring-offset-white;
    border-radius: 4px;
  }

  /* Skip link pour les utilisateurs clavier */
  .skip-link {
    @apply sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4
           focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-white
           focus:rounded-lg focus:font-semibold;
  }
}
```

```tsx
// App.tsx — skip link en premier élément
export function App() {
  return (
    <>
      <a href="#main-content" className="skip-link">
        Aller au contenu principal
      </a>
      <Header />
      <main id="main-content">
        {/* sections */}
      </main>
      <Footer />
    </>
  )
}
```

