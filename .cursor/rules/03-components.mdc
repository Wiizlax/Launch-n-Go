## Pattern du composant `SectionHeader`

```tsx
// src/components/ui/SectionHeader.tsx
import { cn } from '@/utils/cn'

interface SectionHeaderProps {
  tag?: string          // label orange au-dessus — ex: "Nos Services"
  title: string         // titre principal
  subtitle?: string     // sous-titre optionnel
  centered?: boolean    // alignement (défaut: centré)
  className?: string
}

export function SectionHeader({
  tag,
  title,
  subtitle,
  centered = true,
  className,
}: SectionHeaderProps) {
  return (
    <div className={cn('max-w-2xl', centered && 'mx-auto text-center', className)}>
      {tag && (
        <span className="inline-block text-primary font-semibold text-sm uppercase tracking-widest mb-3">
          {tag}
        </span>
      )}
      <h2 className="font-heading text-3xl md:text-4xl font-bold text-dark leading-tight">
        {title}
      </h2>
      {subtitle && (
        <p className="mt-4 text-gray-500 text-lg leading-relaxed">{subtitle}</p>
      )}
    </div>
  )
}
```

