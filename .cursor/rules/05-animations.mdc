## Hook `useScrollReveal` — scroll reveal générique

```ts
// src/hooks/useScrollReveal.ts
import { useInView } from 'framer-motion'
import { useRef } from 'react'

interface ScrollRevealOptions {
  threshold?: number    // 0 à 1, défaut: 0.15
  once?: boolean        // ne déclencher qu'une fois, défaut: true
  rootMargin?: string   // ex: "-50px"
}

/**
 * Retourne une ref et un booléen isInView.
 * Utiliser avec whileInView sur les motion.* elements en général,
 * mais ce hook est utile pour des logiques conditionnelles plus complexes.
 */
export function useScrollReveal({
  threshold = 0.15,
  once = true,
  rootMargin = '0px',
}: ScrollRevealOptions = {}) {
  const ref = useRef<HTMLElement>(null)
  const isInView = useInView(ref, {
    amount: threshold,
    once,
    margin: rootMargin,
  })

  return { ref, isInView }
}
```

