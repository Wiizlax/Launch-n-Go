## Ce qu'il ne faut jamais faire

```tsx
// ❌ Variants inline — impossibles à réutiliser, illisibles
<motion.div
  initial={{ opacity: 0, y: 40, scale: 0.9 }}
  whileInView={{ opacity: 1, y: 0, scale: 1 }}
  transition={{ duration: 0.6, ease: 'easeOut' }}
  viewport={{ once: true }}
/>

// ✅ Importer depuis constants/animations
import { SCALE_UP, TRANSITION_EASE } from '@/constants/animations'
<motion.div variants={SCALE_UP} initial="hidden" whileInView="visible" viewport={{ once: true }} />

// ❌ Animer des propriétés non-performantes
<motion.div animate={{ width: 300, height: 200, left: 50 }} />

// ❌ Oublier viewport once
<motion.div whileInView={{ opacity: 1 }} /> // rejoue à chaque passage !

// ✅
<motion.div whileInView={{ opacity: 1 }} viewport={{ once: true }} />
```
