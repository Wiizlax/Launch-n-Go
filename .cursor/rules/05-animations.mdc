## Hook `useReducedMotion` — accessibilité obligatoire

```ts
// src/hooks/useReducedMotion.ts
import { useReducedMotion as useFramerReducedMotion } from 'framer-motion'

/**
 * Retourne les variants appropriés selon la préférence système.
 * Si l'utilisateur préfère les mouvements réduits, retourne des variants sans déplacement.
 */
export function useSafeMotion() {
  const shouldReduce = useFramerReducedMotion()

  const safeVariant = (variants: Record<string, object>) => {
    if (!shouldReduce) return variants
    // Retirer les propriétés de déplacement, garder uniquement opacity
    return Object.fromEntries(
      Object.entries(variants).map(([key, val]) => [
        key,
        { opacity: (val as Record<string, number>).opacity ?? 1 },
      ])
    )
  }

  return { shouldReduce, safeVariant }
}
```

