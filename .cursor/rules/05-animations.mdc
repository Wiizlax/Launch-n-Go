# Animations — Framer Motion

## Philosophie

- **Purposeful** : chaque animation a une raison d'être (guider l'attention, donner du feedback, révéler du contenu)
- **Performant** : toujours animer `transform` et `opacity` — jamais `width`, `height`, `top`, `left` directement
- **Accessible** : respecter `prefers-reduced-motion` systématiquement
- **DRY** : les variants sont définis dans `src/constants/animations.ts` et importés, jamais inline

---

## Installation

```bash
npm install framer-motion
```

---

## `src/constants/animations.ts` — Bibliothèque de variants réutilisables

```ts
import type { Variants, Transition } from 'framer-motion'

// ── Transitions de base ────────────────────────────────────────────────────────

export const TRANSITION_SMOOTH: Transition = {
  type: 'spring',
  stiffness: 100,
  damping: 20,
  mass: 0.8,
}

export const TRANSITION_SNAPPY: Transition = {
  type: 'spring',
  stiffness: 300,
  damping: 24,
}

export const TRANSITION_EASE: Transition = {
  duration: 0.5,
  ease: [0.25, 0.46, 0.45, 0.94], // ease-out-quart
}

export const TRANSITION_SLOW: Transition = {
  duration: 0.8,
  ease: [0.16, 1, 0.3, 1], // expo-out
}

// ── Variants d'apparition (scroll reveal) ─────────────────────────────────────

/** Fade simple — pour les éléments discrets */
export const FADE_IN: Variants = {
  hidden: { opacity: 0 },
  visible: {
    opacity: 1,
    transition: TRANSITION_EASE,
  },
}

/** Slide depuis le bas — le plus courant pour les sections */
export const FADE_UP: Variants = {
  hidden: { opacity: 0, y: 40 },
  visible: {
    opacity: 1,
    y: 0,
    transition: TRANSITION_EASE,
  },
}

/** Slide depuis la gauche */
export const FADE_LEFT: Variants = {
  hidden: { opacity: 0, x: -40 },
  visible: {
    opacity: 1,
    x: 0,
    transition: TRANSITION_EASE,
  },
}

/** Slide depuis la droite */
export const FADE_RIGHT: Variants = {
  hidden: { opacity: 0, x: 40 },
  visible: {
    opacity: 1,
    x: 0,
    transition: TRANSITION_EASE,
  },
}

/** Scale + fade — pour les cards, badges, éléments focaux */
export const SCALE_IN: Variants = {
  hidden: { opacity: 0, scale: 0.88 },
  visible: {
    opacity: 1,
    scale: 1,
    transition: TRANSITION_SMOOTH,
  },
}

/** Scale depuis le bas avec légère perspective */
export const SCALE_UP: Variants = {
  hidden: { opacity: 0, scale: 0.92, y: 20 },
  visible: {
    opacity: 1,
    scale: 1,
    y: 0,
    transition: TRANSITION_SMOOTH,
  },
}

// ── Variants de conteneur (stagger enfants) ────────────────────────────────────

/**
 * Stagger standard — les enfants apparaissent l'un après l'autre.
 * Utiliser sur le wrapper, appliquer FADE_UP sur chaque enfant.
 */
export const STAGGER_CONTAINER: Variants = {
  hidden: { opacity: 0 },
  visible: {
    opacity: 1,
    transition: {
      staggerChildren: 0.1,
      delayChildren: 0.1,
    },
  },
}

/** Stagger plus rapide — pour les petits éléments nombreux */
export const STAGGER_FAST: Variants = {
  hidden: { opacity: 0 },
  visible: {
    opacity: 1,
    transition: {
      staggerChildren: 0.06,
      delayChildren: 0.05,
    },
  },
}

/** Stagger lent — pour les sections héro ou les grands blocs */
export const STAGGER_SLOW: Variants = {
  hidden: { opacity: 0 },
  visible: {
    opacity: 1,
    transition: {
      staggerChildren: 0.18,
      delayChildren: 0.2,
    },
  },
}

// ── Variants hover ─────────────────────────────────────────────────────────────

export const HOVER_LIFT = {
  rest: { y: 0, boxShadow: '0 4px 24px -4px rgba(0,0,0,0.08)' },
  hover: {
    y: -6,
    boxShadow: '0 16px 48px -8px rgba(0,0,0,0.18)',
    transition: TRANSITION_SNAPPY,
  },
}

export const HOVER_SCALE = {
  rest: { scale: 1 },
  hover: { scale: 1.04, transition: TRANSITION_SNAPPY },
}

export const HOVER_GLOW = {
  rest: { boxShadow: '0 0 0px rgba(255,107,53,0)' },
  hover: {
    boxShadow: '0 8px 32px -4px rgba(255,107,53,0.4)',
    transition: { duration: 0.3 },
  },
}

// ── Variants de texte (lettres / mots) ────────────────────────────────────────

export const WORD_REVEAL: Variants = {
  hidden: {},
  visible: {
    transition: { staggerChildren: 0.06 },
  },
}

export const WORD_CHILD: Variants = {
  hidden: { opacity: 0, y: 20, rotateX: -40 },
