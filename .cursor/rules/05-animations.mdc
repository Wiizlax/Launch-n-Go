## Patterns d'utilisation

### 1. Scroll reveal simple sur une section

```tsx
import { motion } from 'framer-motion'
import { FADE_UP, STAGGER_CONTAINER } from '@/constants/animations'

export function ServicesSection() {
  return (
    <section id="services" className="py-24">
      {/* Conteneur stagger — les enfants apparaissent en cascade */}
      <motion.div
        variants={STAGGER_CONTAINER}
        initial="hidden"
        whileInView="visible"
        viewport={{ once: true, amount: 0.15 }}
      >
        <motion.div variants={FADE_UP}>
          <SectionHeader tag="Nos Services" title="Des solutions complètes" />
        </motion.div>

        <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
          {SERVICES.map((service) => (
            <motion.div key={service.id} variants={FADE_UP}>
              <ServiceCard {...service} />
            </motion.div>
          ))}
        </div>
      </motion.div>
    </section>
  )
}
```

### 2. Cards avec hover lift

```tsx
import { motion } from 'framer-motion'
import { SCALE_UP, HOVER_LIFT } from '@/constants/animations'

export function ServiceCard({ title, description, icon }: ServiceCardProps) {
  return (
    <motion.div
      variants={SCALE_UP}             // apparition au scroll
      initial="rest"
      whileHover="hover"              // état hover
      animate="rest"
      className="rounded-2xl bg-white p-6 cursor-pointer"
    >
      <motion.div variants={HOVER_LIFT}>
        {/* Contenu de la card */}
        <div className="text-primary mb-4">
          <DynamicIcon name={icon} size={32} />
        </div>
        <h3 className="font-heading font-bold text-xl text-dark">{title}</h3>
        <p className="mt-2 text-gray-muted">{description}</p>
      </motion.div>
    </motion.div>
  )
}
```

### 3. Titre hero avec reveal mot par mot

```tsx
import { motion } from 'framer-motion'
import { WORD_REVEAL, WORD_CHILD, FADE_UP, STAGGER_SLOW } from '@/constants/animations'

const title = "On crée les applications web de vos rêves"
const words = title.split(' ')

export function HeroSection() {
  return (
    <motion.section
      variants={STAGGER_SLOW}
      initial="hidden"
      animate="visible"
      className="pt-32 pb-20"
    >
      {/* Titre mot par mot */}
      <motion.h1
        variants={WORD_REVEAL}
        className="font-heading text-5xl md:text-7xl font-bold leading-tight"
      >
        {words.map((word, i) => (
          <motion.span
            key={i}
            variants={WORD_CHILD}
            className="inline-block mr-[0.25em]"
            style={{ display: 'inline-block' }} // nécessaire pour rotateX
          >
            {word}
          </motion.span>
        ))}
      </motion.h1>

      {/* Sous-titre fade up après le titre */}
      <motion.p variants={FADE_UP} className="mt-6 text-xl text-gray-muted max-w-2xl">
        Votre partenaire digital pour créer des applications web...
      </motion.p>

      {/* CTAs avec délai supplémentaire */}
      <motion.div variants={FADE_UP} className="mt-10 flex gap-4">
        <Button size="lg">Démarrer votre projet</Button>
        <Button size="lg" variant="secondary">Voir nos réalisations</Button>
      </motion.div>
    </motion.section>
  )
}
```

### 4. Compteurs animés (stats : 50+, 98%, 5+, 24/7)

```tsx
import { motion, useInView, useMotionValue, useSpring, animate } from 'framer-motion'
import { useEffect, useRef } from 'react'

interface CounterProps {
  from?: number
  to: number
  suffix?: string
  duration?: number
}

export function AnimatedCounter({ from = 0, to, suffix = '', duration = 2 }: CounterProps) {
  const ref = useRef<HTMLSpanElement>(null)
  const isInView = useInView(ref, { once: true })

  useEffect(() => {
    if (!isInView || !ref.current) return

    const controls = animate(from, to, {
      duration,
      ease: [0.16, 1, 0.3, 1],
      onUpdate(value) {
        if (ref.current) {
          ref.current.textContent = Math.round(value) + suffix
        }
      },
    })

    return () => controls.stop()
  }, [isInView, from, to, suffix, duration])

  return <span ref={ref}>{from + suffix}</span>
}

// Usage dans StatsSection
<AnimatedCounter to={50} suffix="+" />    // "50+"
<AnimatedCounter to={98} suffix="%" />    // "98%"
```

### 5. Processus avec ligne de connexion animée

```tsx
import { motion } from 'framer-motion'
import { STAGGER_CONTAINER, SCALE_IN } from '@/constants/animations'

export function ProcessSection() {
  return (
    <section className="py-24">
      <motion.div
        className="flex flex-col md:flex-row items-start gap-8 relative"
        variants={STAGGER_CONTAINER}
        initial="hidden"
        whileInView="visible"
        viewport={{ once: true, amount: 0.2 }}
      >
        {/* Ligne de progression animée */}
        <motion.div
          className="hidden md:block absolute top-8 left-[12%] right-[12%] h-0.5 bg-gray-100"
          initial={{ scaleX: 0, originX: 0 }}
          whileInView={{ scaleX: 1 }}
          viewport={{ once: true }}
          transition={{ duration: 1.2, ease: [0.16, 1, 0.3, 1], delay: 0.3 }}
        />

        {PROCESS_STEPS.map((step, index) => (
          <motion.div
            key={step.id}
            variants={SCALE_IN}
            className="flex-1 flex flex-col items-center text-center relative z-10"
          >
            {/* Numéro d'étape */}
            <motion.div
              className="w-16 h-16 rounded-full bg-primary text-white flex items-center justify-center font-bold text-lg mb-4"
              whileHover={{ scale: 1.1, rotate: 5 }}
              transition={{ type: 'spring', stiffness: 400 }}
            >
              {String(index + 1).padStart(2, '0')}
            </motion.div>
            <h3 className="font-heading font-bold text-lg">{step.title}</h3>
            <p className="mt-2 text-gray-muted text-sm">{step.description}</p>
          </motion.div>
        ))}
      </motion.div>
    </section>
  )
}
```

